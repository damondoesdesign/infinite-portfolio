{
  "name": "infinite-portfolio",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "sync": "node scripts/sync-gallery.mjs && npm run merge",
    "generate": "node scripts/generate-placeholders.mjs",
    "dev": "npm run sync && vite",
    "merge": "node scripts/merge-projects.mjs",
    "prebuild": "npm run sync",
    "build": "tsc && vite build",
    "build:pages": "GITHUB_PAGES=true npm run build && touch docs/.nojekyll",
    "publish": "bash scripts/publish-gallery.sh",
    "watch": "node scripts/watch-gallery.mjs",
    "preview": "vite preview"
  },
  "devDependencies": {
    "chokidar": "^4.0.3",
    "typescript": "~6.0.2",
    "vite": "^8.0.12"
  }
}
